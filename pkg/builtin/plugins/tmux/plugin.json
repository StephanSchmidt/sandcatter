{
  "name": "tmux",
  "version": "1.0.0",
  "description": "Terminal multiplexer with 256-color support, mouse integration, and custom keybindings",
  "apt_packages": ["tmux"],
  "fonts": [
    "fonts-dejavu",
    "fonts-liberation",
    "fonts-noto-core",
    "fonts-noto-ui-core",
    "fontconfig"
  ],
  "locale_packages": ["locales"],
  "compose_command": "bash -c 'cd /workspaces/* 2>/dev/null; exec tmux'",
  "files": [
    {
      "source": "files/tmux.conf",
      "destination": "/etc/skel/.tmux.conf",
      "chmod": "644"
    },
    {
      "source": "files/tmux.conf",
      "destination": "/home/vscode/.tmux.conf",
      "chmod": "644"
    }
  ],
  "compose_env": {
    "TERM": "xterm-256color"
  },
  "locale_setup": {
    "locale": "en_US.UTF-8",
    "generate": true
  }
}
